<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="google-site-verification" content="XfqAGvIOpHrWN0Q9qbviS6urHh_olDaNcZyTMw-yuQg" />
<meta name="naver-site-verification" content="d50d8575b2990156d7aee8c092287983fa2e2c7c" />
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ if .IsHome }}{{ .Site.Title }}{{ else }}{{ .Title }} · {{ .Site.Title }}{{ end }}</title>
<meta name="description" content="{{ with .Description }}{{ . }}{{ else }}{{ .Site.Params.description }}{{ end }}">
{{ with .Params.canonical }}<link rel="canonical" href="{{ . }}">{{ else }}<link rel="canonical" href="{{ .Permalink }}">{{ end }}
<meta property="og:title" content="{{ .Title }}">
<meta property="og:description" content="{{ with .Description }}{{ . }}{{ else }}{{ .Site.Params.description }}{{ end }}">
<meta property="og:type" content="{{ if .IsPage }}article{{ else }}website{{ end }}">
<meta property="og:url" content="{{ .Permalink }}">
<meta property="og:locale" content="ko_KR">
{{ with .OutputFormats.Get "rss" }}<link rel="alternate" type="application/rss+xml" href="{{ .Permalink }}" title="{{ $.Site.Title }}">{{ end }}
<link rel="preconnect" href="https://cdn.jsdelivr.net">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">
<style>
:root{
  --paper:#FBFBF8; --ink:#15171C; --muted:#6A6E76; --line:#E8E7E1; --surface:#FFFFFF;
  --brand:#0E7C66; --brand-ink:#0A5A4A; --brand-wash:#EAF4F0;
  --charge:#F2A93B; --charge-ink:#9A6608;
  --maxw:720px; --radius:14px;
  --shadow:0 1px 2px rgba(20,23,28,.04), 0 8px 24px rgba(20,23,28,.06);
  --panel-ink:#F4F5F2; --panel-muted:#9AA1A8;
  --mono:ui-monospace,SFMono-Regular,Menlo,"SF Mono",monospace;
}
*{box-sizing:border-box}
html{-webkit-text-size-adjust:100%; scroll-behavior:smooth}
body{
  margin:0; background:var(--paper); color:var(--ink);
  font-family:"Pretendard Variable",Pretendard,-apple-system,BlinkMacSystemFont,"Apple SD Gothic Neo","Noto Sans KR",system-ui,sans-serif;
  font-size:17px; line-height:1.75; letter-spacing:-0.004em;
  word-break:keep-all; overflow-wrap:break-word;
  font-variant-numeric:tabular-nums; -webkit-font-smoothing:antialiased;
}
.wrap{max-width:var(--maxw); margin:0 auto; padding:0 20px}
a{color:var(--brand-ink); text-decoration:none}
a:hover{text-decoration:underline; text-underline-offset:3px}
:focus-visible{outline:2.5px solid var(--brand); outline-offset:3px; border-radius:3px}
.skip{position:absolute; left:-999px}
.skip:focus{left:12px; top:12px; background:var(--ink); color:#fff; padding:8px 12px; border-radius:8px; z-index:50}

/* ── 헤더: 충전 바 시그니처 ── */
.site-header{position:sticky; top:0; z-index:20; background:rgba(251,251,248,.86); backdrop-filter:saturate(180%) blur(10px); border-bottom:1px solid var(--line)}
.site-header .charge{height:3px; background:linear-gradient(90deg,var(--brand) 0%, var(--brand) 55%, var(--charge) 55%, var(--charge) 100%); transform-origin:left; animation:charge 1.1s cubic-bezier(.2,.7,.2,1) both}
@keyframes charge{from{transform:scaleX(0)} to{transform:scaleX(1)}}
.site-header .bar{display:flex; align-items:center; height:58px}
.brand{display:inline-flex; align-items:center; gap:9px; font-weight:800; font-size:1.06rem; color:var(--ink); letter-spacing:-0.02em}
.brand:hover{text-decoration:none}
.brand .dot{width:11px; height:18px; border-radius:3px; background:var(--brand); position:relative; box-shadow:inset 0 -9px 0 var(--charge)}
.brand .dot::after{content:""; position:absolute; top:-3px; left:3px; width:5px; height:2.5px; border-radius:2px 2px 0 0; background:var(--brand)}

main.wrap{padding:38px 20px 64px}

/* ── 홈 목록 ── */
.home-head{margin:6px 0 30px}
.home-title{font-size:2rem; font-weight:800; letter-spacing:-0.035em; line-height:1.25; margin:0}
.home-desc{color:var(--muted); margin:.55em 0 0; font-size:1.02rem}
.home-rule{height:1px; background:var(--line); margin:26px 0 4px}
.post-list{list-style:none; margin:0; padding:0; display:grid; gap:14px}
.post-card{background:var(--surface); border:1px solid var(--line); border-radius:var(--radius); padding:20px 22px; transition:transform .15s ease, box-shadow .15s ease, border-color .15s ease}
.post-card:hover{transform:translateY(-2px); box-shadow:var(--shadow); border-color:#dcdbd4}
.post-card a.tt{display:block; font-size:1.2rem; font-weight:750; color:var(--ink); letter-spacing:-0.022em; line-height:1.4}
.post-card a.tt:hover{color:var(--brand-ink); text-decoration:none}
.post-card .excerpt{color:var(--muted); margin:.5em 0 .7em; font-size:.96rem; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden}
.post-card .date{display:inline-flex; align-items:center; gap:7px; color:var(--muted); font-size:.8rem; font-weight:600}
.post-card .date::before{content:""; width:14px; height:8px; border-radius:2px; background:linear-gradient(90deg,var(--brand) 60%, var(--line) 60%)}

/* ══ 홈 고급화: 디바이스 패널 히어로 ══ */
.hero{margin:22px 0 42px}
.hero__panel{
  position:relative; overflow:hidden; color:var(--panel-ink);
  background:radial-gradient(125% 150% at 16% -10%, #1C222A 0%, #12151B 58%, #0E1116 100%);
  border:1px solid rgba(255,255,255,.07); border-radius:24px;
  padding:40px 32px 30px;
  box-shadow:0 1px 0 rgba(255,255,255,.06) inset, 0 -60px 80px -60px rgba(14,124,102,.35) inset, 0 34px 80px -36px rgba(14,124,102,.55), 0 22px 48px -26px rgba(20,23,28,.6);
}
.hero__panel::before{content:""; position:absolute; top:-45%; right:-12%; width:62%; height:130%; background:radial-gradient(circle at center, rgba(242,169,59,.17), transparent 62%); pointer-events:none}
.hero__panel > *{position:relative}
.hero__eyebrow{display:inline-flex; align-items:center; gap:9px; margin:0 0 18px; font-size:.74rem; font-weight:700; letter-spacing:.15em; color:var(--charge)}
.hero__eyebrow .tick{width:9px; height:9px; border-radius:2px; background:var(--charge); box-shadow:0 0 11px rgba(242,169,59,.85)}
.hero__title{margin:0; font-size:clamp(2rem,6.6vw,2.95rem); font-weight:850; line-height:1.16; letter-spacing:-0.042em; color:var(--panel-ink)}
.hero__title .hl{color:var(--charge)}
.hero__sub{margin:.72em 0 0; max-width:32ch; color:var(--panel-muted); font-size:1.04rem; line-height:1.6}

/* 충전 게이지 = 배터리(브랜드 마크 확대) */
.gauge{display:inline-flex; align-items:center; gap:5px; margin:26px 0 24px}
.gauge__body{display:flex; align-items:center; gap:5px; padding:6px; border:2px solid rgba(255,255,255,.2); border-radius:8px; background:rgba(0,0,0,.22)}
.gauge .cell{width:24px; height:18px; border-radius:2px; background:rgba(255,255,255,.06); position:relative; overflow:hidden}
.gauge .cell::after{content:""; position:absolute; inset:0; border-radius:2px; background:var(--brand); box-shadow:0 0 12px rgba(14,124,102,.75); transform:scaleX(0); transform-origin:left; animation:cell-fill .5s cubic-bezier(.2,.7,.2,1) forwards; animation-delay:calc(.5s + var(--i) * .085s)}
.gauge .cell--charge::after{background:var(--charge); box-shadow:0 0 15px rgba(242,169,59,.9)}
.gauge__cap{width:5px; height:14px; border-radius:0 3px 3px 0; background:rgba(255,255,255,.3)}
@keyframes cell-fill{to{transform:scaleX(1)}}

/* 신뢰 스트립 */
.hero__trust{display:flex; flex-wrap:wrap; align-items:center; gap:9px 16px; padding-top:22px; border-top:1px solid rgba(255,255,255,.08); font-size:.86rem; color:var(--panel-muted)}
.hero__trust .trust b{color:var(--panel-ink); font-weight:700; font-family:var(--mono); font-variant-numeric:tabular-nums; letter-spacing:-0.01em}
.hero__trust .trust--link{color:var(--charge); font-weight:700; margin-left:auto}
.hero__trust .trust--link:hover{text-decoration:none; color:#ffd089}

/* ── 섹션 라벨 ── */
.block{margin:0 0 36px}
.block__label{display:flex; align-items:center; gap:10px; margin:0 0 16px; font-size:.78rem; font-weight:800; letter-spacing:.13em; color:var(--muted)}
.block__label::before{content:""; width:18px; height:4px; border-radius:3px; background:var(--charge)}
.block__n{font-family:var(--mono); font-size:.8rem; color:var(--brand-ink); background:var(--brand-wash); border-radius:6px; padding:1px 8px; font-weight:700}

/* 최신 가이드 (featured) */
.feat{display:block; position:relative; overflow:hidden; background:var(--surface); border:1px solid var(--line); border-radius:18px; padding:26px 26px 22px; transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease}
.feat::before{content:""; position:absolute; left:0; top:0; bottom:0; width:4px; background:linear-gradient(180deg,var(--brand),var(--charge)); transform:scaleY(0); transform-origin:top; transition:transform .22s cubic-bezier(.2,.7,.2,1)}
.feat:hover{transform:translateY(-3px); box-shadow:var(--shadow); border-color:#d6dbd5; text-decoration:none}
.feat:hover::before{transform:scaleY(1)}
.feat__title{margin:0; font-size:1.5rem; font-weight:800; line-height:1.32; letter-spacing:-0.03em; color:var(--ink)}
.feat:hover .feat__title{color:var(--brand-ink)}
.feat__desc{margin:.6em 0 0; color:var(--muted); font-size:1rem; line-height:1.6; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden}
.feat__meta{display:flex; flex-wrap:wrap; align-items:center; gap:8px; margin-top:16px}

/* 칩 / 날짜 (공통) */
.chip{font-size:.76rem; font-weight:700; color:var(--brand-ink); background:var(--brand-wash); border:1px solid #d6e9e2; border-radius:7px; padding:3px 9px; letter-spacing:-0.01em}
.chip--sm{font-size:.72rem; padding:2px 7px}
.when{font-family:var(--mono); font-size:.78rem; font-weight:600; color:var(--muted); margin-left:auto; display:inline-flex; align-items:center; gap:7px; font-variant-numeric:tabular-nums}
.when::before{content:""; width:14px; height:8px; border-radius:2px; background:linear-gradient(90deg,var(--brand) 62%, rgba(14,124,102,.16) 62%)}

/* 전체 가이드 리스트 */
.guide-list{list-style:none; margin:0; padding:0; display:grid; gap:12px}
.guide-row{background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 20px; transition:transform .15s ease, box-shadow .15s ease, border-color .15s ease}
.guide-row:hover{transform:translateY(-2px); box-shadow:var(--shadow); border-color:#d6dbd5}
.guide-row__t{display:block; font-size:1.16rem; font-weight:750; color:var(--ink); letter-spacing:-0.022em; line-height:1.4}
.guide-row__t:hover{color:var(--brand-ink); text-decoration:none}
.guide-row__d{margin:.45em 0 0; color:var(--muted); font-size:.94rem; line-height:1.55; display:-webkit-box; -webkit-line-clamp:1; -webkit-box-orient:vertical; overflow:hidden}
.guide-row__meta{display:flex; flex-wrap:wrap; align-items:center; gap:7px; margin-top:12px}

.empty{background:var(--surface); border:1px dashed #d9d8d1; border-radius:16px; padding:36px 20px; text-align:center; color:var(--muted); font-size:.98rem}

/* 신뢰 밴드 (3칸) */
.pillars{list-style:none; margin:0; padding:0; display:grid; grid-template-columns:repeat(3,1fr); gap:12px}
.pillar{background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:18px 16px}
.pillar__ico{width:30px; height:30px; border-radius:8px; background:var(--brand-wash); display:flex; align-items:center; justify-content:center; margin-bottom:11px}
.pillar__ico svg{width:17px; height:17px; stroke:var(--brand-ink); fill:none; stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round}
.pillar__t{display:block; margin:0; font-size:.98rem; font-weight:750; color:var(--ink); letter-spacing:-0.02em}
.pillar__d{margin:.35em 0 0; font-size:.85rem; line-height:1.5; color:var(--muted)}
a.pillar__t:hover{color:var(--brand-ink); text-decoration:none}
@media (max-width:560px){
  .pillars{grid-template-columns:1fr}
  .pillar{display:flex; align-items:center; gap:13px; padding:15px 16px}
  .pillar__ico{margin-bottom:0; flex:0 0 auto}
  .pillar__body{flex:1; min-width:0}
}

/* ── 글 ── */
.post-meta{display:flex; align-items:center; gap:9px; color:var(--muted); font-size:.84rem; font-weight:600; margin:0 0 18px}
.post-meta .pill{background:var(--brand-wash); color:var(--brand-ink); padding:3px 10px; border-radius:999px; font-size:.76rem}

.prose h1{font-size:2.05rem; font-weight:800; line-height:1.28; letter-spacing:-0.038em; margin:.1em 0 .65em}
.prose h2{font-size:1.42rem; font-weight:750; letter-spacing:-0.03em; line-height:1.35; margin:2.2em 0 .65em; padding-top:.55em; position:relative}
.prose h2::before{content:""; position:absolute; top:0; left:0; width:34px; height:4px; border-radius:3px; background:var(--charge)}
.prose h3{font-size:1.14rem; font-weight:700; letter-spacing:-0.02em; margin:1.7em 0 .45em; color:var(--brand-ink)}
.prose p{margin:0 0 1.15em}
.prose strong{font-weight:750}
.prose ul,.prose ol{padding-left:1.25em; margin:0 0 1.15em}
.prose li{margin:.35em 0}
.prose li::marker{color:var(--brand)}
.prose hr{border:0; border-top:1px solid var(--line); margin:2.2em 0}
.prose del{color:var(--muted); text-decoration-color:var(--line)}
.prose a{text-decoration:underline; text-underline-offset:2px; text-decoration-color:#bfe0d6}

/* 인사이트 콜아웃 */
.prose blockquote{margin:1.5em 0; padding:16px 18px; background:var(--brand-wash); border:1px solid #d6e9e2; border-left:4px solid var(--brand); border-radius:10px; color:var(--brand-ink)}
.prose blockquote p{margin:0}
.prose blockquote p + p{margin-top:.6em}

/* 스펙시트 비교표 (주인공) */
.prose table{display:block; overflow-x:auto; -webkit-overflow-scrolling:touch; width:100%; border-collapse:collapse; margin:1.5em 0; font-size:.92rem; border:1px solid var(--line); border-radius:12px}
.prose thead th{background:var(--brand); color:#fff; font-weight:700; white-space:nowrap; letter-spacing:-0.01em}
.prose th,.prose td{padding:11px 14px; border-bottom:1px solid var(--line); border-right:1px solid var(--line); text-align:left; vertical-align:top; white-space:nowrap}
.prose th:last-child,.prose td:last-child{border-right:0}
.prose tbody tr:nth-child(even){background:#FAFAF7}
.prose tbody tr:hover{background:var(--brand-wash)}
.prose tbody td:first-child{font-weight:700; color:var(--ink)}
/* ── 전환: 추천 카드 + 차분한 CTA ── */
.atlas-cta{display:inline-flex; align-items:center; justify-content:center; gap:6px; background:var(--brand); color:#fff !important; font-weight:700; font-size:.9rem; padding:9px 16px; border-radius:9px; text-decoration:none !important; transition:background .12s ease}
.atlas-cta:hover{background:var(--brand-ink); text-decoration:none !important}
.atlas-cta--sm{padding:6px 12px; font-size:.82rem; border-radius:7px}
.atlas-cards{display:grid; grid-template-columns:1fr; gap:12px; margin:1.5em 0}
@media (min-width:600px){.atlas-cards{grid-template-columns:1fr 1fr}}
.atlas-card{background:var(--surface); border:1px solid var(--line); border-radius:var(--radius); padding:18px; display:flex; flex-direction:column; gap:9px}
.atlas-card__name{font-weight:800; font-size:1.04rem; letter-spacing:-0.02em; color:var(--ink)}
.atlas-card__reason{margin:0; font-size:.9rem; color:var(--brand-ink); line-height:1.5}
.atlas-card__specs{display:flex; flex-wrap:wrap; gap:6px}
.atlas-card__spec{font-size:.78rem; color:var(--muted); background:#F4F5F2; border:1px solid var(--line); border-radius:7px; padding:3px 8px}
.atlas-card__spec b{color:var(--ink); font-weight:700}
.atlas-card__buy{display:flex; align-items:center; justify-content:space-between; gap:12px; margin-top:4px}
.atlas-card__price{font-size:1.12rem; font-weight:800; letter-spacing:-0.02em; color:var(--ink)}
/* 관련 글(체류·순환) */
.atlas-related{display:grid; grid-template-columns:1fr; gap:10px; margin:1.2em 0}
@media (min-width:600px){.atlas-related{grid-template-columns:1fr 1fr}}
.atlas-related .atlas-rel{display:flex; align-items:center; justify-content:space-between; gap:12px; background:var(--surface); border:1px solid var(--line); border-radius:11px; padding:15px 17px; text-decoration:none !important; transition:border-color .15s ease, box-shadow .15s ease, transform .12s ease}
.atlas-related .atlas-rel:hover{border-color:var(--brand); box-shadow:var(--shadow); transform:translateY(-1px); text-decoration:none !important}
.atlas-rel__t{font-weight:700; font-size:.96rem; color:var(--ink); letter-spacing:-0.02em; line-height:1.4}
.atlas-rel__a{color:var(--brand); font-weight:800; flex:none}
.prose code{background:#F2F3F0; padding:.12em .4em; border-radius:5px; font-size:.88em; font-family:ui-monospace,SFMono-Regular,Menlo,monospace}

/* ── 푸터 ── */
.site-footer{border-top:1px solid var(--line); background:var(--surface)}
.site-footer .wrap{padding:26px 20px}
.foot-nav{display:flex; flex-wrap:wrap; gap:8px 20px; margin-bottom:14px}
.foot-nav a{font-size:.88rem; font-weight:600; color:var(--ink); text-decoration:none}
.foot-nav a:hover{color:var(--brand-ink); text-decoration:underline}
.disclosure{font-size:.82rem; color:var(--muted); line-height:1.65; margin:0}
.disclosure b{color:var(--ink); font-weight:700}
.disclosure a{color:var(--brand-ink)}
.copyright{font-size:.78rem; color:var(--muted); margin:.7em 0 0}

@media (max-width:480px){
  body{font-size:16px}
  .prose h1{font-size:1.62rem}
  .prose h2{font-size:1.24rem}
  .home-title{font-size:1.62rem}
  main.wrap{padding-top:28px}
  .hero__panel{padding:32px 22px 26px; border-radius:20px}
  .gauge .cell{width:22px; height:15px}
  .feat{padding:22px 20px 18px}
  .feat__title{font-size:1.32rem}
  .when{margin-left:0}
}
@media (prefers-reduced-motion:reduce){
  .site-header .charge{animation:none}
  .post-card{transition:none}
  .gauge .cell::after{animation:none; transform:scaleX(1)}
  .feat,.feat::before,.guide-row{transition:none}
  html{scroll-behavior:auto}
}
</style>

</head>
<body>
<a class="skip" href="#main">본문 바로가기</a>
<header class="site-header">
  <div class="charge"></div>
  <div class="wrap bar">
    <a class="brand" href="{{ "/" | relURL }}"><span class="dot"></span>{{ .Site.Title }}</a>
  </div>
</header>
<main id="main" class="wrap">
  {{ block "main" . }}{{ end }}
</main>
<footer class="site-footer">
  <div class="wrap">
    <nav class="foot-nav">
      <a href="{{ "/about/" | relURL }}">소개</a>
      <a href="{{ "/methodology/" | relURL }}">비교 방법</a>
      <a href="{{ "/disclosure/" | relURL }}">제휴 고지</a>
      <a href="{{ "/privacy/" | relURL }}">개인정보처리방침</a>
    </nav>
    <p class="disclosure"><b>고지</b> · 본 사이트의 제품 링크 일부는 제휴(파트너스) 링크이며, 구매 시 일정 수수료를 받을 수 있습니다(가격에 영향 없음). 자세한 내용은 <a href="{{ "/disclosure/" | relURL }}">제휴 고지</a>를 참고하세요.</p>
    <p class="copyright">© {{ now.Year }} {{ .Site.Title }}</p>
  </div>
</footer>
</body>
</html>
